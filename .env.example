ANTHROPIC_API_KEY=your_anthropic_api_key_here
SESSION_SECRET=generate_a_long_random_string_for_this
GROQ_API_KEY=your_groq_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username_without_at_sign
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
PORT=3000

# BASE_URL — the single source of truth for this deploy's public URL. Used to
# derive the Google OAuth redirect URI, the Telegram webhook URL (only if
# POLLING is ever set false), and the calendar push-webhook address. Update
# this ONE variable whenever the deployed domain changes — nothing else
# should hardcode a full URL. No trailing slash.
# Local dev: leave unset, everything falls back to http://localhost:3000.
BASE_URL=https://your-service.up.railway.app

# Legacy — SERVER_URL/GOOGLE_REDIRECT_URI are still read as a fallback if
# BASE_URL isn't set, but BASE_URL always wins when present. Don't set both;
# a stale GOOGLE_REDIRECT_URI here after a domain change is exactly the bug
# BASE_URL exists to prevent.
# SERVER_URL=https://your-service.up.railway.app
# GOOGLE_REDIRECT_URI=https://your-service.up.railway.app/auth/google/callback

# Google Calendar (optional)
# Get from https://console.cloud.google.com → APIs & Services → Credentials
# Enable the Google Calendar API, create OAuth 2.0 Client ID (Web application)
# Add {BASE_URL}/auth/google/callback to Authorized redirect URIs there —
# Google rejects the OAuth flow if this doesn't EXACTLY match what BASE_URL
# derives, so update it there too whenever BASE_URL changes.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_WEBHOOK_TOKEN=lifeline-secret-change-this
